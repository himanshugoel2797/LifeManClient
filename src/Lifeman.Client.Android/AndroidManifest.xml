<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">
  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <!-- Foreground service type is required on Android 14+. dataSync is
       the closest fit for "uploading observations + listening for
       deliveries"; the lifeman agent is essentially a sync client. -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
  <!-- PACKAGE_USAGE_STATS is a "signature|appop" permission. Declaring
       it here doesn't auto-grant it; the user must enable it in
       Settings → Special app access → Usage data access. The
       foreground-app collector no-ops silently if the grant is missing. -->
  <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
                   tools:ignore="ProtectedPermissions" />
  <!-- Calendar events. Runtime permission (dangerous group). -->
  <uses-permission android:name="android.permission.READ_CALENDAR" />
  <!-- Location. FINE drives the passive listener; BACKGROUND keeps it
       flowing when the foreground service is the user's only active
       component. Both are runtime permissions; the user must
       additionally grant background access via the "Allow all the
       time" dialog on Android 10+. -->
  <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
  <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
  <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
  <!-- Bluetooth audio surface. BLUETOOTH (legacy) covers <=30; CONNECT
       is the Android 12+ (S, API 31+) runtime permission for talking
       to paired devices. -->
  <uses-permission android:name="android.permission.BLUETOOTH"
                   android:maxSdkVersion="30" />
  <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
  <!-- Needed by RichPackagePickerActivity. Android 11+ otherwise hides
       all packages outside our manifest <queries> block, which would
       leave the picker showing only the few apps we explicitly
       declared a relationship to. Play Store treats this as a
       restricted permission, but the lifeman client is sideloaded
       (CLIENT_DESIGN §"Distribution") so the policy doesn't apply. -->
  <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
                   tools:ignore="QueryAllPackagesPermission" />

  <application
    android:allowBackup="false"
    android:icon="@mipmap/appicon"
    android:label="@string/app_name"
    android:roundIcon="@mipmap/appicon_round"
    android:supportsRtl="true"
    android:usesCleartextTraffic="true">
    <!-- Cleartext is on so dev / emulator can reach a localhost kernel
         via 10.0.2.2:8390 (or a LAN IP on a real phone). The kernel
         doesn't terminate TLS itself; production deployments are
         expected to front it with a reverse proxy that does. -->
  </application>
</manifest>
